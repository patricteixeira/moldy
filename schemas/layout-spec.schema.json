{
  "$defs": {
    "AssetLayer": {
      "additionalProperties": false,
      "description": "Asset imutável do Brand IR posicionado pelo layout.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "const": "asset",
          "default": "asset",
          "title": "Kind",
          "type": "string"
        },
        "assetToken": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Assettoken",
          "type": "string"
        },
        "area": {
          "maxItems": 4,
          "minItems": 4,
          "prefixItems": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          ],
          "title": "Area",
          "type": "array"
        },
        "fit": {
          "default": "contain",
          "enum": [
            "contain",
            "cover"
          ],
          "title": "Fit",
          "type": "string"
        },
        "opacity": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Opacity",
          "type": "number"
        },
        "zIndex": {
          "default": 0,
          "maximum": 20,
          "minimum": 0,
          "title": "Zindex",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "assetToken",
        "area"
      ],
      "title": "AssetLayer",
      "type": "object"
    },
    "Background": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "color"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "colorToken": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "colorToken"
            ]
          }
        }
      ],
      "description": "Fundo sólido por token de cor ou fornecido por um slot de imagem.",
      "properties": {
        "kind": {
          "enum": [
            "color",
            "image-slot"
          ],
          "title": "Kind",
          "type": "string"
        },
        "colorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Colortoken"
        }
      },
      "required": [
        "kind"
      ],
      "title": "Background",
      "type": "object"
    },
    "Canvas": {
      "additionalProperties": false,
      "description": "Dimensões e margem segura de um perfil de saída, em pixels.",
      "properties": {
        "widthPx": {
          "exclusiveMinimum": 0,
          "title": "Widthpx",
          "type": "integer"
        },
        "heightPx": {
          "exclusiveMinimum": 0,
          "title": "Heightpx",
          "type": "integer"
        },
        "safeAreaPx": {
          "minimum": 0,
          "title": "Safeareapx",
          "type": "integer"
        }
      },
      "required": [
        "widthPx",
        "heightPx",
        "safeAreaPx"
      ],
      "title": "Canvas",
      "type": "object"
    },
    "MotifLayer": {
      "additionalProperties": false,
      "description": "Aplicação fixa de um motivo pertencente ao vocabulário do Brand IR.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "const": "motif",
          "default": "motif",
          "title": "Kind",
          "type": "string"
        },
        "motif": {
          "const": "diagonal-lines",
          "title": "Motif",
          "type": "string"
        },
        "area": {
          "maxItems": 4,
          "minItems": 4,
          "prefixItems": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          ],
          "title": "Area",
          "type": "array"
        },
        "colorToken": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Colortoken",
          "type": "string"
        },
        "opacity": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Opacity",
          "type": "number"
        },
        "strokeWidthPx": {
          "exclusiveMinimum": 0.0,
          "maximum": 20.0,
          "title": "Strokewidthpx",
          "type": "number"
        },
        "spacingPx": {
          "exclusiveMinimum": 0.0,
          "maximum": 256.0,
          "title": "Spacingpx",
          "type": "number"
        },
        "zIndex": {
          "default": 0,
          "maximum": 20,
          "minimum": 0,
          "title": "Zindex",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "motif",
        "area",
        "colorToken",
        "strokeWidthPx",
        "spacingPx"
      ],
      "title": "MotifLayer",
      "type": "object"
    },
    "ShapeLayer": {
      "additionalProperties": false,
      "description": "Forma geométrica fixa e fechada, sem estilos livres.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "const": "shape",
          "default": "shape",
          "title": "Kind",
          "type": "string"
        },
        "shape": {
          "enum": [
            "rectangle",
            "circle"
          ],
          "title": "Shape",
          "type": "string"
        },
        "area": {
          "maxItems": 4,
          "minItems": 4,
          "prefixItems": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          ],
          "title": "Area",
          "type": "array"
        },
        "colorToken": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Colortoken",
          "type": "string"
        },
        "opacity": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Opacity",
          "type": "number"
        },
        "zIndex": {
          "default": 0,
          "maximum": 20,
          "minimum": 0,
          "title": "Zindex",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "shape",
        "area",
        "colorToken"
      ],
      "title": "ShapeLayer",
      "type": "object"
    },
    "Slot": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "text"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "role": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "role"
            ]
          }
        }
      ],
      "description": "Região editável de um layout, com limites para adaptação e validação.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "text",
            "image",
            "logo"
          ],
          "title": "Kind",
          "type": "string"
        },
        "role": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Role"
        },
        "colorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Colortoken"
        },
        "maxChars": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maxchars"
        },
        "minResolution": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                },
                {
                  "exclusiveMinimum": 0,
                  "type": "integer"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minresolution"
        },
        "area": {
          "maxItems": 4,
          "minItems": 4,
          "prefixItems": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          ],
          "title": "Area",
          "type": "array"
        },
        "fit": {
          "default": "shrink-within-role-range",
          "enum": [
            "shrink-within-role-range",
            "fixed"
          ],
          "title": "Fit",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "zIndex": {
          "anyOf": [
            {
              "maximum": 20,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Zindex"
        },
        "opacity": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Opacity",
          "type": "number"
        },
        "textAlign": {
          "default": "left",
          "enum": [
            "left",
            "center",
            "right"
          ],
          "title": "Textalign",
          "type": "string"
        },
        "textTransform": {
          "default": "none",
          "enum": [
            "none",
            "uppercase"
          ],
          "title": "Texttransform",
          "type": "string"
        },
        "letterSpacingEm": {
          "default": 0.0,
          "maximum": 0.5,
          "minimum": -0.1,
          "title": "Letterspacingem",
          "type": "number"
        },
        "fillMode": {
          "default": "fill",
          "enum": [
            "fill",
            "stroke"
          ],
          "title": "Fillmode",
          "type": "string"
        },
        "strokeColorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strokecolortoken"
        },
        "strokeWidthPx": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 20.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strokewidthpx"
        },
        "assetToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assettoken"
        },
        "emphasisColorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Emphasiscolortoken"
        },
        "textFormat": {
          "default": "plain",
          "enum": [
            "plain",
            "zero-padded"
          ],
          "title": "Textformat",
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind",
        "area"
      ],
      "title": "Slot",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "const": "post-1x1"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "canvas": {
            "properties": {
              "widthPx": {
                "const": 1080
              },
              "heightPx": {
                "const": 1080
              },
              "safeAreaPx": {
                "const": 48
              }
            },
            "required": [
              "widthPx",
              "heightPx",
              "safeAreaPx"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile": {
            "const": "post-4x5"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "canvas": {
            "properties": {
              "widthPx": {
                "const": 1080
              },
              "heightPx": {
                "const": 1350
              },
              "safeAreaPx": {
                "const": 48
              }
            },
            "required": [
              "widthPx",
              "heightPx",
              "safeAreaPx"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile": {
            "const": "story-9x16"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "canvas": {
            "properties": {
              "widthPx": {
                "const": 1080
              },
              "heightPx": {
                "const": 1920
              },
              "safeAreaPx": {
                "const": 64
              }
            },
            "required": [
              "widthPx",
              "heightPx",
              "safeAreaPx"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile": {
            "const": "doc-a4"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "canvas": {
            "properties": {
              "widthPx": {
                "const": 794
              },
              "heightPx": {
                "const": 1123
              },
              "safeAreaPx": {
                "const": 76
              }
            },
            "required": [
              "widthPx",
              "heightPx",
              "safeAreaPx"
            ]
          }
        }
      }
    }
  ],
  "description": "Layout declarativo adaptado para um dos perfis publicados pelo motor.",
  "properties": {
    "id": {
      "minLength": 1,
      "pattern": ".*\\S.*",
      "title": "Id",
      "type": "string"
    },
    "profile": {
      "enum": [
        "post-1x1",
        "post-4x5",
        "story-9x16",
        "doc-a4"
      ],
      "title": "Profile",
      "type": "string"
    },
    "namePt": {
      "minLength": 1,
      "pattern": ".*\\S.*",
      "title": "Namept",
      "type": "string"
    },
    "canvas": {
      "$ref": "#/$defs/Canvas"
    },
    "background": {
      "$ref": "#/$defs/Background"
    },
    "slots": {
      "items": {
        "$ref": "#/$defs/Slot"
      },
      "title": "Slots",
      "type": "array"
    },
    "compositionMode": {
      "anyOf": [
        {
          "enum": [
            "light",
            "dark"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Compositionmode"
    },
    "lockedLayers": {
      "items": {
        "discriminator": {
          "mapping": {
            "asset": "#/$defs/AssetLayer",
            "motif": "#/$defs/MotifLayer",
            "shape": "#/$defs/ShapeLayer"
          },
          "propertyName": "kind"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/ShapeLayer"
          },
          {
            "$ref": "#/$defs/MotifLayer"
          },
          {
            "$ref": "#/$defs/AssetLayer"
          }
        ]
      },
      "title": "Lockedlayers",
      "type": "array"
    }
  },
  "required": [
    "id",
    "profile",
    "namePt",
    "canvas",
    "background",
    "slots"
  ],
  "title": "LayoutSpec",
  "type": "object"
}
