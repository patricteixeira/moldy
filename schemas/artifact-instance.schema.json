    "Slot": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "text"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "role": {
                "minLength": 1,
