{
  "$defs": {
    "ArtifactValue": {
      "additionalProperties": false,
      "description": "Valor acompanhado de seu estado de verdade e proveniência legível.",
      "properties": {
        "status": {
          "enum": [
            "confirmed",
            "derived",
            "placeholder",
            "missing"
          ],
          "title": "Status",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextValue"
            },
            {
              "$ref": "#/$defs/ImageValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "sourcePt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sourcept"
        }
      },
      "required": [
        "status"
      ],
      "title": "ArtifactValue",
      "type": "object"
    },
    "AssetLayer": {
      "additionalProperties": false,
      "description": "Asset imutável do Brand IR posicionado pelo layout.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "const": "asset",
          "default": "asset",
          "title": "Kind",
          "type": "string"
        },
        "assetToken": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Assettoken",
          "type": "string"
        },
        "area": {
          "maxItems": 4,
          "minItems": 4,
          "prefixItems": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          ],
          "title": "Area",
          "type": "array"
        },
        "fit": {
          "default": "contain",
          "enum": [
            "contain",
            "cover"
          ],
          "title": "Fit",
          "type": "string"
        },
        "opacity": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Opacity",
          "type": "number"
        },
        "zIndex": {
          "default": 0,
          "maximum": 20,
          "minimum": 0,
          "title": "Zindex",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "assetToken",
        "area"
      ],
      "title": "AssetLayer",
      "type": "object"
    },
    "Background": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "color"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "colorToken": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "colorToken"
            ]
          }
        }
      ],
      "description": "Fundo sólido por token de cor ou fornecido por um slot de imagem.",
      "properties": {
        "kind": {
          "enum": [
            "color",
            "image-slot"
          ],
          "title": "Kind",
          "type": "string"
        },
        "colorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Colortoken"
        }
      },
      "required": [
        "kind"
      ],
      "title": "Background",
      "type": "object"
    },
    "Canvas": {
      "additionalProperties": false,
      "description": "Dimensões e margem segura de um perfil de saída, em pixels.",
      "properties": {
        "widthPx": {
          "exclusiveMinimum": 0,
          "title": "Widthpx",
          "type": "integer"
        },
        "heightPx": {
          "exclusiveMinimum": 0,
          "title": "Heightpx",
          "type": "integer"
        },
        "safeAreaPx": {
          "minimum": 0,
          "title": "Safeareapx",
          "type": "integer"
        }
      },
      "required": [
        "widthPx",
        "heightPx",
        "safeAreaPx"
      ],
      "title": "Canvas",
      "type": "object"
    },
    "ImageValue": {
      "additionalProperties": false,
      "description": "Imagem fornecida para um slot, opcionalmente acompanhada de seu hash.",
      "properties": {
        "kind": {
          "const": "image",
          "default": "image",
          "title": "Kind",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        }
      },
      "required": [
        "path"
      ],
      "title": "ImageValue",
      "type": "object"
    },
    "LayerOverride": {
      "additionalProperties": false,
      "description": "Ajustes autorais de uma instância sem alterar o layout publicado.",
      "properties": {
        "area": {
          "anyOf": [
            {
              "maxItems": 4,
              "minItems": 4,
              "prefixItems": [
                {
                  "maximum": 32768,
                  "minimum": -32768,
                  "type": "integer"
                },
                {
                  "maximum": 32768,
                  "minimum": -32768,
                  "type": "integer"
                },
                {
                  "exclusiveMinimum": 0,
                  "maximum": 32768,
                  "type": "integer"
                },
                {
                  "exclusiveMinimum": 0,
                  "maximum": 32768,
                  "type": "integer"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Area"
        },
        "rotationDeg": {
          "anyOf": [
            {
              "maximum": 180.0,
              "minimum": -180.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rotationdeg"
        },
        "opacity": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Opacity"
        },
        "hidden": {
          "default": false,
          "title": "Hidden",
          "type": "boolean"
        },
        "zIndex": {
          "anyOf": [
            {
              "maximum": 20,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Zindex"
        },
        "colorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Colortoken"
        },
        "fontToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fonttoken"
        },
        "fontSizePx": {
          "anyOf": [
            {
              "maximum": 1024.0,
              "minimum": 6.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fontsizepx"
        },
        "fontWeight": {
          "anyOf": [
            {
              "maximum": 900,
              "minimum": 100,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fontweight"
        },
        "fontStyle": {
          "anyOf": [
            {
              "enum": [
                "normal",
                "italic"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fontstyle"
        },
        "lineHeight": {
          "anyOf": [
            {
              "maximum": 3.0,
              "minimum": 0.5,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lineheight"
        },
        "letterSpacingEm": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": -0.25,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Letterspacingem"
        },
        "textAlign": {
          "anyOf": [
            {
              "enum": [
                "left",
                "center",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Textalign"
        },
        "textTransform": {
          "anyOf": [
            {
              "enum": [
                "none",
                "uppercase"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Texttransform"
        },
        "fillMode": {
          "anyOf": [
            {
              "enum": [
                "fill",
                "stroke"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fillmode"
        },
        "strokeColorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strokecolortoken"
        },
        "strokeWidthPx": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 20.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strokewidthpx"
        },
        "fit": {
          "anyOf": [
            {
              "enum": [
                "contain",
                "cover"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fit"
        },
        "spacingPx": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 256.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spacingpx"
        }
      },
      "title": "LayerOverride",
      "type": "object"
    },
    "LayoutSpec": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "profile": {
                "const": "post-1x1"
              }
            },
            "required": [
              "profile"
            ]
          },
          "then": {
            "properties": {
              "canvas": {
                "properties": {
                  "widthPx": {
                    "const": 1080
                  },
                  "heightPx": {
                    "const": 1080
                  },
                  "safeAreaPx": {
                    "const": 48
                  }
                },
                "required": [
                  "widthPx",
                  "heightPx",
                  "safeAreaPx"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profile": {
                "const": "post-4x5"
              }
            },
            "required": [
              "profile"
            ]
          },
          "then": {
            "properties": {
              "canvas": {
                "properties": {
                  "widthPx": {
                    "const": 1080
                  },
                  "heightPx": {
                    "const": 1350
                  },
                  "safeAreaPx": {
                    "const": 48
                  }
                },
                "required": [
                  "widthPx",
                  "heightPx",
                  "safeAreaPx"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profile": {
                "const": "story-9x16"
              }
            },
            "required": [
              "profile"
            ]
          },
          "then": {
            "properties": {
              "canvas": {
                "properties": {
                  "widthPx": {
                    "const": 1080
                  },
                  "heightPx": {
                    "const": 1920
                  },
                  "safeAreaPx": {
                    "const": 64
                  }
                },
                "required": [
                  "widthPx",
                  "heightPx",
                  "safeAreaPx"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "profile": {
                "const": "doc-a4"
              }
            },
            "required": [
              "profile"
            ]
          },
          "then": {
            "properties": {
              "canvas": {
                "properties": {
                  "widthPx": {
                    "const": 794
                  },
                  "heightPx": {
                    "const": 1123
                  },
                  "safeAreaPx": {
                    "const": 76
                  }
                },
                "required": [
                  "widthPx",
                  "heightPx",
                  "safeAreaPx"
                ]
              }
            }
          }
        }
      ],
      "description": "Layout declarativo adaptado para um dos perfis publicados pelo motor.",
      "properties": {
        "id": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Id",
          "type": "string"
        },
        "profile": {
          "enum": [
            "post-1x1",
            "post-4x5",
            "story-9x16",
            "doc-a4"
          ],
          "title": "Profile",
          "type": "string"
        },
        "namePt": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Namept",
          "type": "string"
        },
        "canvas": {
          "$ref": "#/$defs/Canvas"
        },
        "background": {
          "$ref": "#/$defs/Background"
        },
        "slots": {
          "items": {
            "$ref": "#/$defs/Slot"
          },
          "title": "Slots",
          "type": "array"
        },
        "compositionMode": {
          "anyOf": [
            {
              "enum": [
                "light",
                "dark"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compositionmode"
        },
        "lockedLayers": {
          "items": {
            "discriminator": {
              "mapping": {
                "asset": "#/$defs/AssetLayer",
                "motif": "#/$defs/MotifLayer",
                "shape": "#/$defs/ShapeLayer"
              },
              "propertyName": "kind"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/ShapeLayer"
              },
              {
                "$ref": "#/$defs/MotifLayer"
              },
              {
                "$ref": "#/$defs/AssetLayer"
              }
            ]
          },
          "title": "Lockedlayers",
          "type": "array"
        },
        "templateRef": {
          "anyOf": [
            {
              "$ref": "#/$defs/TemplateRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sceneGraph": {
          "anyOf": [
            {
              "$ref": "#/$defs/SceneGraph"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id",
        "profile",
        "namePt",
        "canvas",
        "background",
        "slots"
      ],
      "title": "LayoutSpec",
      "type": "object"
    },
    "MotifLayer": {
