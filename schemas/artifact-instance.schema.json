        "id": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "group",
            "frame",
            "stack",
            "grid"
          ],
          "title": "Kind",
          "type": "string"
        },
        "area": {
          "maxItems": 4,
          "minItems": 4,
          "prefixItems": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          ],
          "title": "Area",
          "type": "array"
        },
        "children": {
          "items": {
            "minLength": 1,
            "pattern": ".*\\S.*",
            "type": "string"
          },
          "minItems": 1,
          "title": "Children",
          "type": "array"
        },
        "direction": {
          "anyOf": [
            {
              "enum": [
                "horizontal",
                "vertical"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direction"
        },
        "gapPx": {
          "default": 0,
          "minimum": 0,
          "title": "Gappx",
          "type": "integer"
        },
        "columns": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Columns"
        },
        "clip": {
          "default": false,
          "title": "Clip",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "kind",
        "area",
        "children"
      ],
      "title": "SceneGroup",
      "type": "object"
    },
