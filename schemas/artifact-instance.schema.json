    "SceneGraph": {
      "additionalProperties": false,
      "description": "Estrutura v2 preservada junto ao layout plano compilado.",
      "properties": {
        "schemaVersion": {
          "const": "2.0.0",
          "default": "2.0.0",
          "title": "Schemaversion",
          "type": "string"
        },
        "roots": {
