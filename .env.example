# Copie para `.env` e troque antes do primeiro `docker compose up`.
# Use somente caracteres URL-safe (letras, números, ponto, sublinhado, til ou hífen).
BRANDRT_TOKEN=troque-por-um-token-local-seguro
BRANDRT_DB_PASSWORD=troque-por-uma-senha-local-segura
BRANDRT_PORT=8080

# Fontes abertas usam catálogo fixado e proxy interno; nenhuma API key é necessária.

# Uso exclusivo do deploy oficial online operado pelo Digital Artisan.
# Não habilite esta opção em instalações open source locais.
VITE_SYNAPSIS_FONT_BASE_URL=
